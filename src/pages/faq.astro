---
import MainLayout from '../layouts/MainLayout.astro';
import { BUSINESS, ORGANIZATION_SCHEMA } from '../utils/constants';
import { formatPhoneLink } from '../utils/helpers';

const title = 'FAQ & Paperwork Help | MG Salvage';
const description = 'Common questions about selling your junk car in NC. Title help, paperwork requirements, pricing, and pickup process explained. Call (919) 777-5427 for immediate assistance.';
const keywords = 'junk car faq, sell car without title NC, car title help, junk car paperwork, vehicle salvage requirements, lost title NC';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'FAQ', url: '/faq' }
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much can I get for my junk car?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: `Prices vary based on vehicle weight, condition, current scrap metal prices, and salvageable parts. Most junk cars range from $200-$1,000+. Running vehicles and those with valuable parts command higher prices. Call ${BUSINESS.phoneDisplay} for an instant quote.`
      }
    },
    {
      '@type': 'Question',
      name: 'Do I need a title to sell my junk car?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ideally, yes. However, we can sometimes purchase vehicles without titles with proper documentation. If you have a lost title, we can guide you through obtaining a duplicate from the NC DMV. Each situation is different—call us to discuss your specific case.'
      }
    },
    {
      '@type': 'Question',
      name: 'Is towing really free?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes, absolutely. Free towing is included with every vehicle we purchase. There are no hidden fees or deductions from your payment for towing.'
      }
    },
    {
      '@type': 'Question',
      name: 'How quickly can you pick up my car?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Same-day pickup is often available if you call before noon. Otherwise, we typically offer next-day pickup. We work around your schedule, including evenings and weekends when needed.'
      }
    }
  ]
};

const generalFaqs = [
  {
    q: 'How much can I get for my junk car?',
    a: `Prices vary based on vehicle weight, condition, current scrap metal prices, and salvageable parts. Most junk cars range from $200-$1,000+. Running vehicles, trucks, SUVs, and those with valuable parts command higher prices. Call ${BUSINESS.phoneDisplay} for an instant, no-obligation quote.`
  },
  {
    q: 'Is towing really free?',
    a: 'Yes, absolutely. Free towing is included with every vehicle we purchase. There are no hidden fees or deductions from your payment for towing. We come to your location, wherever that may be, and haul your vehicle away at no cost to you.'
  },
  {
    q: 'How quickly can you pick up my car?',
    a: 'Same-day pickup is often available if you call before noon. Otherwise, we typically offer next-day pickup. We work around your schedule, including evenings and weekends when needed. Business accounts may qualify for scheduled recurring pickups.'
  },
  {
    q: 'Do you buy cars in any condition?',
    a: 'Yes. We buy vehicles in all conditions: running or not, damaged, totaled, rusted, with missing parts, or completely intact. We also buy cars with mechanical problems, electrical issues, body damage, flood damage, and fire damage.'
  },
  {
    q: 'What types of vehicles do you buy?',
    a: 'We buy cars, trucks, SUVs, vans, minivans, and some commercial vehicles. If you have something unusual, give us a call—we can likely help or point you in the right direction.'
  }
];

const titleFaqs = [
  {
    q: 'Do I need a title to sell my junk car?',
    a: 'Ideally, yes—you need a title to legally transfer ownership. However, we understand that titles get lost. We can guide you through obtaining a duplicate title from the NC DMV. In some cases, we can work with vehicles that have proper alternative documentation. Call us to discuss your situation.'
  },
  {
    q: 'What if I lost my title?',
    a: `You'll need to obtain a duplicate title from the NC DMV. The process involves filling out form MVR-4, paying a $21 fee, and waiting approximately 10-15 business days. We can help guide you through this process. If you need to sell urgently, we may be able to work with a bill of sale and ID, depending on the situation.`
  },
  {
    q: 'What if the title is in someone else\'s name?',
    a: 'The person named on the title must sign it over to us, or you need to properly transfer the title into your name first. If the owner is deceased, you may need estate paperwork. Call us—we can explain the requirements for your specific situation.'
  },
  {
    q: 'Can I sell a car with a lien on it?',
    a: 'Generally, no. A lien means the lender has a legal claim to the vehicle. The lien must be satisfied (paid off) before the title can be transferred. The bank or lender typically holds the title until the loan is paid in full.'
  },
  {
    q: 'What paperwork do I need to have ready?',
    a: 'Ideally: the vehicle title (signed over to us), your valid ID, and the keys if you have them. If you don\'t have all of these, call us—we may still be able to help depending on your situation.'
  }
];

const processFaqs = [
  {
    q: 'How does the process work?',
    a: 'Simple: (1) Call or fill out our form for a quote, (2) Accept our offer and schedule pickup, (3) We arrive, verify the vehicle, handle paperwork, and pay you, (4) We tow the vehicle away. Most pickups take 15-30 minutes from arrival to departure.'
  },
  {
    q: 'Do I need to be present when you pick up the car?',
    a: 'While we prefer you to be present to sign paperwork and receive payment, it\'s not always necessary. If you can\'t be there, we can arrange for someone else to be present with proper authorization, or handle the transaction remotely with proper documentation.'
  },
  {
    q: 'How do I get paid?',
    a: 'We typically pay with cash or check at the time of pickup—your choice. For business accounts or higher-value vehicles, we can also arrange other payment methods. You get paid when we arrive, not after.'
  },
  {
    q: 'What happens to my car after you take it?',
    a: 'Vehicles are taken to our licensed salvage facility where they are processed according to EPA and state regulations. Usable parts may be recovered, fluids are properly drained and recycled, and the remaining metal is processed for recycling. Everything is handled in an environmentally responsible manner.'
  },
  {
    q: 'Do I need to cancel my insurance?',
    a: 'Yes, you should contact your insurance company to cancel coverage once the vehicle is picked up and ownership is transferred. Keep your insurance active until the transaction is complete. We recommend getting a receipt or release of liability from us.'
  }
];

const locationFaqs = [
  {
    q: 'What areas do you serve?',
    a: 'We primarily serve central North Carolina including Sanford, Fayetteville, Pittsboro, Carthage, Lillington, Southern Pines, and surrounding areas. Based in Sanford, NC, we typically service within a 50-mile radius. Don\'t see your area? Call us anyway—we may still be able to help or recommend a trusted partner.'
  },
  {
    q: 'Do you pick up from rural locations?',
    a: 'Yes. Our tow operators are experienced with rural properties, farms, and locations off paved roads. Just let us know about any access issues (narrow driveways, gates, etc.) when you schedule so we bring the right equipment.'
  },
  {
    q: 'Do you pick up from apartment complexes and condos?',
    a: 'Yes, we regularly pick up from apartment complexes, condos, and townhomes. We just ask that you ensure we have access permission if required by your property management, and let us know about any parking or access restrictions.'
  }
];

const businessFaqs = [
  {
    q: 'Do you work with businesses?',
    a: 'Absolutely. We provide specialized services for mechanic shops, auto body shops, used car dealers, fleet operators, and other businesses. This includes scheduled pickups, bulk vehicle removal, and flexible payment terms. Visit our Business Vehicle Removal page to learn more.'
  },
  {
    q: 'Can you handle multiple vehicles at once?',
    a: 'Yes, we can arrange bulk pickups for businesses or individuals with multiple vehicles. Whether it\'s 2 cars or 20, we can coordinate the logistics and often offer better rates for volume.'
  },
  {
    q: 'Do you provide receipts for tax purposes?',
    a: 'Yes, we provide detailed receipts for all transactions. Business customers receive proper documentation suitable for accounting and tax records. Individual sellers also receive receipts documenting the sale.'
  }
];
---

<MainLayout title={title} description={description} keywords={keywords} schema={[faqSchema]} breadcrumbs={breadcrumbs}>
  <!-- Header -->
  <section class="section-padding bg-gradient-to-br from-charcoal-900 to-graphite-900 text-white">
    <div class="container-content">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-display-lg font-bold text-white mb-6">Frequently Asked Questions</h1>
        <p class="text-xl text-charcoal-300">
          Everything you need to know about selling your junk car in North Carolina.
        </p>
      </div>
    </div>
  </section>

  <!-- Quick Contact CTA -->
  <section class="py-8 bg-brand-orange">
    <div class="container-content">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-white text-lg font-medium">
          Can't find your answer? Call us for immediate help.
        </p>
        <a href={formatPhoneLink(BUSINESS.phone)} class="inline-flex items-center bg-white text-brand-orange px-6 py-3 rounded-lg font-semibold hover:bg-charcoal-100 transition-colors">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {BUSINESS.phoneDisplay}
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ Categories -->
  <section class="section-padding bg-white">
    <div class="container-content">
      <div class="grid lg:grid-cols-4 gap-8">
        <!-- Navigation -->
        <div class="lg:sticky lg:top-8 lg:self-start">
          <h3 class="font-semibold text-charcoal-900 mb-4">FAQ Categories</h3>
          <nav class="space-y-2">
            <a href="#general" class="block p-3 rounded-lg hover:bg-charcoal-50 text-charcoal-700 hover:text-brand-orange transition-colors">
              General Questions
            </a>
            <a href="#titles" class="block p-3 rounded-lg hover:bg-charcoal-50 text-charcoal-700 hover:text-brand-orange transition-colors">
              Title & Paperwork
            </a>
            <a href="#process" class="block p-3 rounded-lg hover:bg-charcoal-50 text-charcoal-700 hover:text-brand-orange transition-colors">
              The Process
            </a>
            <a href="#locations" class="block p-3 rounded-lg hover:bg-charcoal-50 text-charcoal-700 hover:text-brand-orange transition-colors">
              Service Areas
            </a>
            <a href="#business" class="block p-3 rounded-lg hover:bg-charcoal-50 text-charcoal-700 hover:text-brand-orange transition-colors">
              Business Services
            </a>
          </nav>
        </div>

        <!-- FAQ Content -->
        <div class="lg:col-span-3 space-y-12">
          <!-- General -->
          <div id="general">
            <h2 class="text-display-sm font-bold text-charcoal-950 mb-6 pb-2 border-b-2 border-brand-orange inline-block">
              General Questions
            </h2>
            <div class="space-y-4">
              {generalFaqs.map((faq, index) => (
                <details class="bg-charcoal-50 rounded-xl border border-charcoal-100 group" id={`general-${index}`}>
                  <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
                    <span class="font-semibold text-charcoal-900 pr-4">{faq.q}</span>
                    <span class="w-8 h-8 bg-brand-orange/10 text-brand-orange rounded-full flex items-center justify-center flex-shrink-0 group-open:rotate-180 transition-transform">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                      </svg>
                    </span>
                  </summary>
                  <div class="px-6 pb-6 text-charcoal-600 prose prose-charcoal">
                    {faq.a}
                  </div>
                </details>
              ))}
            </div>
          </div>

          <!-- Title & Paperwork -->
          <div id="titles">
            <h2 class="text-display-sm font-bold text-charcoal-950 mb-6 pb-2 border-b-2 border-brand-orange inline-block">
              Title & Paperwork
            </h2>
            <div class="space-y-4">
              {titleFaqs.map((faq, index) => (
                <details class="bg-charcoal-50 rounded-xl border border-charcoal-100 group" id={`title-${index}`}>
                  <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
                    <span class="font-semibold text-charcoal-900 pr-4">{faq.q}</span>
                    <span class="w-8 h-8 bg-brand-orange/10 text-brand-orange rounded-full flex items-center justify-center flex-shrink-0 group-open:rotate-180 transition-transform">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                      </svg>
                    </span>
                  </summary>
                  <div class="px-6 pb-6 text-charcoal-600 prose prose-charcoal">
                    {faq.a}
                  </div>
                </details>
              ))}
            </div>
          </div>

          <!-- Process -->
          <div id="process">
            <h2 class="text-display-sm font-bold text-charcoal-950 mb-6 pb-2 border-b-2 border-brand-orange inline-block">
              The Process
            </h2>
            <div class="space-y-4">
              {processFaqs.map((faq, index) => (
                <details class="bg-charcoal-50 rounded-xl border border-charcoal-100 group" id={`process-${index}`}>
                  <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
                    <span class="font-semibold text-charcoal-900 pr-4">{faq.q}</span>
                    <span class="w-8 h-8 bg-brand-orange/10 text-brand-orange rounded-full flex items-center justify-center flex-shrink-0 group-open:rotate-180 transition-transform">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                      </svg>
                    </span>
                  </summary>
                  <div class="px-6 pb-6 text-charcoal-600 prose prose-charcoal">
                    {faq.a}
                  </div>
                </details>
              ))}
            </div>
          </div>

          <!-- Locations -->
          <div id="locations">
            <h2 class="text-display-sm font-bold text-charcoal-950 mb-6 pb-2 border-b-2 border-brand-orange inline-block">
              Service Areas & Pickup
            </h2>
            <div class="space-y-4">
              {locationFaqs.map((faq, index) => (
                <details class="bg-charcoal-50 rounded-xl border border-charcoal-100 group" id={`location-${index}`}>
                  <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
                    <span class="font-semibold text-charcoal-900 pr-4">{faq.q}</span>
                    <span class="w-8 h-8 bg-brand-orange/10 text-brand-orange rounded-full flex items-center justify-center flex-shrink-0 group-open:rotate-180 transition-transform">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                      </svg>
                    </span>
                  </summary>
                  <div class="px-6 pb-6 text-charcoal-600 prose prose-charcoal">
                    {faq.a}
                  </div>
                </details>
              ))}
            </div>
          </div>

          <!-- Business -->
          <div id="business">
            <h2 class="text-display-sm font-bold text-charcoal-950 mb-6 pb-2 border-b-2 border-brand-orange inline-block">
              Business Services
            </h2>
            <div class="space-y-4">
              {businessFaqs.map((faq, index) => (
                <details class="bg-charcoal-50 rounded-xl border border-charcoal-100 group" id={`business-${index}`}>
                  <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
                    <span class="font-semibold text-charcoal-900 pr-4">{faq.q}</span>
                    <span class="w-8 h-8 bg-brand-orange/10 text-brand-orange rounded-full flex items-center justify-center flex-shrink-0 group-open:rotate-180 transition-transform">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                      </svg>
                    </span>
                  </summary>
                  <div class="px-6 pb-6 text-charcoal-600 prose prose-charcoal">
                    {faq.a}
                  </div>
                </details>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Still Have Questions -->
  <section class="section-padding bg-charcoal-50">
    <div class="container-content">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-display-md font-bold text-charcoal-950 mb-6">Still Have Questions?</h2>
        <p class="text-body-lg text-charcoal-600 mb-8">
          We're here to help. Call us for immediate assistance or fill out a form and we'll get back to you quickly.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={formatPhoneLink(BUSINESS.phone)} class="btn-primary text-lg py-4 px-8 inline-flex items-center justify-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call {BUSINESS.phoneDisplay}
          </a>
          <a href="/contact" class="btn-outline text-lg py-4 px-8 inline-flex items-center justify-center">
            Contact Us
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<script>
  // Open FAQ if hash is present
  if (window.location.hash) {
    const target = document.querySelector(window.location.hash);
    if (target) {
      target.setAttribute('open', 'true');
      target.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }
</script>
