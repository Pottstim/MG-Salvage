---
import MainLayout from '../../layouts/MainLayout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import HowItWorks from '../../components/sections/HowItWorks.astro';
import TestimonialsSection from '../../components/sections/TestimonialsSection.astro';
import ConsumerEstimateForm from '../../components/forms/ConsumerEstimateForm.astro';
import { BUSINESS, SERVICE_AREAS, ORGANIZATION_SCHEMA } from '../../utils/constants';
import { formatPhoneLink } from '../../utils/helpers';

const cityName = 'Spring Lake';
const citySlug = 'spring-lake';
const countyName = 'Cumberland';
const title = `Cash for Junk Cars ${cityName} NC | Free Towing & Same-Day Pickup`;
const description = `Get cash for your junk car in ${cityName}, NC. Free towing, same-day pickup available. Licensed salvage buyer serving ${cityName}, Fort Bragg area, and ${countyName} County. Call (919) 777-5427.`;
const keywords = `cash for junk cars ${cityName.toLowerCase().replace(' ', '-')}, junk car removal ${cityName.toLowerCase().replace(' ', '-')}, sell my junk car ${cityName.toLowerCase().replace(' ', '-')}, free towing ${cityName.toLowerCase().replace(' ', '-')}, vehicle salvage spring lake nc`;

const schema = {
  '@type': 'LocalBusiness',
  name: `MG Salvage - ${cityName}`,
  description: description,
  url: `https://mgsalvage.com/cities/${citySlug}`,
  telephone: BUSINESS.phone,
  address: {
    '@type': 'PostalAddress',
    addressLocality: cityName,
    addressRegion: 'NC',
    addressCountry: 'US'
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: '35.1679',
    longitude: '-78.9728'
  },
  areaServed: {
    '@type': 'City',
    name: cityName,
    containedInPlace: {
      '@type': 'State',
      name: 'North Carolina'
    }
  }
};

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Service Areas', url: '/areas' },
  { name: cityName, url: `/cities/${citySlug}` }
];

const nearbyAreas = SERVICE_AREAS.filter(a => ['Fayetteville', 'Hope Mills', 'Sanford', 'Lillington'].includes(a.name));

const localFaqs = [
  {
    q: `How quickly can you pick up my junk car in ${cityName}?`,
    a: `We offer next-day pickup for ${cityName} and the Fort Bragg area, with same-day service often available depending on our route. We regularly travel between Sanford and Fayetteville, making ${cityName} a convenient stop along the way.`
  },
  {
    q: `Do you service the military community in ${cityName} and Fort Bragg?`,
    a: `Absolutely! We proudly serve military members and families in ${cityName}, Fort Bragg, and the surrounding military communities. We understand the unique needs of military customers, including quick turnaround times for PCS moves.`
  },
  {
    q: `What areas of ${cityName} do you service?`,
    a: `We service all of ${cityName} including the downtown area, neighborhoods near Fort Bragg, and communities throughout the municipality. We also cover the broader ${countyName} County area.`
  },
  {
    q: `How much can I get for my junk car in ${cityName}?`,
    a: `Prices vary based on vehicle weight, condition, and current scrap metal markets. Most vehicles in ${cityName} range from $200-$1,000+. Running vehicles and those with valuable parts command higher prices. Call for an instant quote.`
  }
];

const localLandmarks = [
  'Fort Bragg Military Base',
  'Spring Lake Middle School',
  'Anderson Creek County Park',
  'Spring Lake Recreation Center',
  'Cumberland County'
];
---

<MainLayout title={title} description={description} keywords={keywords} schema={[schema]} breadcrumbs={breadcrumbs}>
  <HeroSection 
    variant="local"
    location={cityName}
    showForm={true}
    formType="consumer"
  />

  <!-- Local Content -->
  <section class="section-padding bg-white">
    <div class="container-content">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-display-md font-bold text-charcoal-950 mb-6">Cash for Junk Cars in {cityName}, NC</h2>
          <p class="text-body-lg text-charcoal-600 mb-6">
            {cityName} and the Fort Bragg military community trust MG Salvage for reliable junk car removal 
            throughout {countyName} County. We proudly serve military families and civilians alike, 
            offering fast service and fair prices from Sanford to Fayetteville.
          </p>
          <p class="text-body-lg text-charcoal-600 mb-8">
            Whether you're stationed at Fort Bragg, living in {cityName}, or anywhere in the 
            surrounding {countyName} County area, we come to you. Free towing, fair prices, 
            and professional service—that's our promise to {cityName} residents.
          </p>

          <div class="bg-charcoal-50 rounded-xl p-6 border border-charcoal-100">
            <h4 class="font-semibold text-charcoal-900 mb-3">We're Local To:</h4>
            <div class="flex flex-wrap gap-2">
              {localLandmarks.map(landmark => (
                <span class="bg-white px-3 py-1 rounded-full text-sm text-charcoal-700 border border-charcoal-200">
                  {landmark}
                </span>
              ))}
            </div>
          </div>
        </div>

        <div class="bg-charcoal-50 rounded-2xl p-8 border border-charcoal-100">
          <h3 class="text-2xl font-bold text-charcoal-950 mb-6">Get Your {cityName} Quote</h3>
          <ConsumerEstimateForm location={cityName} showTitle={false} />
        </div>
      </div>
    </div>
  </section>

  <!-- Military Community Section -->
  <section class="section-padding bg-brand-teal/5">
    <div class="container-content">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-8">
          <span class="inline-flex items-center bg-brand-teal/10 text-brand-teal-dark px-4 py-2 rounded-full text-sm font-medium mb-4">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            Military Friendly Service
          </span>
          <h2 class="text-display-md font-bold text-charcoal-950 mb-4">Proudly Serving Fort Bragg & Military Families</h2>
          <p class="text-charcoal-600">
            We understand the unique needs of military members facing PCS moves or deployment.
            Fast, reliable service for the Spring Lake and Fort Bragg community.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-white rounded-xl p-6 shadow-sm border border-charcoal-100">
            <div class="w-12 h-12 bg-brand-teal/10 text-brand-teal rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-charcoal-900 mb-2">Quick Turnaround</h3>
            <p class="text-charcoal-600 text-sm">Fast pickup for tight timelines and PCS schedules</p>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-sm border border-charcoal-100">
            <div class="w-12 h-12 bg-brand-teal/10 text-brand-teal rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-charcoal-900 mb-2">Paperwork Help</h3>
            <p class="text-charcoal-600 text-sm">Assistance with all documentation requirements</p>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-sm border border-charcoal-100">
            <div class="w-12 h-12 bg-brand-teal/10 text-brand-teal rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-charcoal-900 mb-2">Cash on Pickup</h3>
            <p class="text-charcoal-600 text-sm">Immediate payment, no waiting for checks to clear</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Local Matters -->
  <section class="section-padding bg-charcoal-50">
    <div class="container-content">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-display-md font-bold text-charcoal-950 mb-4">Why Choose a Local {cityName} Buyer?</h2>
        <p class="text-charcoal-600">
          Working with a local salvage company offers advantages that national chains can't match.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-charcoal-100 text-center">
          <div class="w-14 h-14 bg-brand-orange/10 text-brand-orange rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-charcoal-900 mb-2">Fast Response</h3>
          <p class="text-charcoal-600 text-sm">Next-day pickup available throughout {countyName} County</p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-charcoal-100 text-center">
          <div class="w-14 h-14 bg-brand-orange/10 text-brand-orange rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-charcoal-900 mb-2">Local Knowledge</h3>
          <p class="text-charcoal-600 text-sm">We know {cityName}, military housing areas, and base access</p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-charcoal-100 text-center">
          <div class="w-14 h-14 bg-brand-orange/10 text-brand-orange rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-charcoal-900 mb-2">Personal Service</h3>
          <p class="text-charcoal-600 text-sm">Deal directly with the owners, not a call center</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Local FAQs -->
  <section class="section-padding bg-white">
    <div class="container-content">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-display-md font-bold text-charcoal-950 text-center mb-8">Common Questions for {cityName} Residents</h2>

        <div class="space-y-4">
          {localFaqs.map((faq, index) => (
            <details class="bg-charcoal-50 rounded-xl border border-charcoal-100 group">
              <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
                <span class="font-semibold text-charcoal-900 pr-4">{faq.q}</span>
                <span class="w-8 h-8 bg-brand-orange/10 text-brand-orange rounded-full flex items-center justify-center flex-shrink-0 group-open:rotate-180 transition-transform">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </span>
              </summary>
              <div class="px-6 pb-6 text-charcoal-600">
                {faq.a}
              </div>
            </details>
          ))}
        </div>

        <div class="text-center mt-8">
          <a href="/faq" class="inline-flex items-center text-brand-orange font-medium hover:text-brand-orange-dark">
            View all FAQs
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Nearby Areas -->
  <section class="section-padding bg-charcoal-50">
    <div class="container-content">
      <h2 class="text-display-md font-bold text-charcoal-950 text-center mb-8">Also Serving Areas Near {cityName}</h2>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 max-w-4xl mx-auto">
        {nearbyAreas.map(area => (
          <a 
            href={`/cities/${area.slug}`}
            class="bg-white rounded-lg p-4 text-center shadow-sm hover:shadow-md transition-shadow border border-charcoal-100"
          >
            <div class="font-semibold text-charcoal-900">{area.name}</div>
            <div class="text-sm text-charcoal-500">{area.distance}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <HowItWorks variant="consumer" />
  <TestimonialsSection />

  <!-- CTA Section -->
  <section class="section-padding bg-gradient-to-br from-charcoal-900 to-graphite-900 text-white">
    <div class="container-content">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-display-md font-bold text-white mb-6">Sell Your Junk Car in {cityName} Today</h2>
        <p class="text-xl text-charcoal-300 mb-8">
          Local service, fair prices, same-day pickup available. Get your quote now.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/sell-your-junk-car" class="btn-primary text-lg py-4 px-8">
            Get My Quote
          </a>
          <a href={formatPhoneLink(BUSINESS.phone)} class="btn-outline border-white text-white hover:bg-white hover:text-charcoal-900 text-lg py-4 px-8">
            Call {BUSINESS.phoneDisplay}
          </a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
