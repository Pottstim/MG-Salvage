---
import MainLayout from '../layouts/MainLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import { BUSINESS, SERVICE_AREAS, ORGANIZATION_SCHEMA } from '../utils/constants';
import { formatPhoneLink } from '../utils/helpers';

const title = 'Service Areas | MG Salvage - Sanford, Fayetteville & More';
const description = 'MG Salvage serves Sanford, Fayetteville, Pittsboro, Carthage, Lillington and surrounding areas in central NC. Free junk car removal with towing included.';
const keywords = 'junk car removal service areas, cash for cars sanford, junk car buyer fayetteville, vehicle salvage pittsboro, car removal carthage nc';

const schema = {
  '@type': 'Service',
  name: 'Junk Car Removal Service Areas',
  provider: ORGANIZATION_SCHEMA,
  areaServed: SERVICE_AREAS.map(area => ({
    '@type': 'City',
    name: area.name,
    containedInPlace: {
      '@type': 'State',
      name: 'North Carolina'
    }
  })),
  description: description
};

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Service Areas', url: '/areas' }
];

const counties = [
  { name: 'Lee', cities: SERVICE_AREAS.filter(a => a.county === 'Lee') },
  { name: 'Cumberland', cities: SERVICE_AREAS.filter(a => a.county === 'Cumberland') },
  { name: 'Chatham', cities: SERVICE_AREAS.filter(a => a.county === 'Chatham') },
  { name: 'Moore', cities: SERVICE_AREAS.filter(a => a.county === 'Moore') },
  { name: 'Harnett', cities: SERVICE_AREAS.filter(a => a.county === 'Harnett') }
];
---

<MainLayout title={title} description={description} keywords={keywords} schema={[schema]} breadcrumbs={breadcrumbs}>
  <HeroSection 
    variant="home"
    title="Our Service Areas"
    subtitle="Junk Car Removal Across Central NC"
    description="We provide professional junk car removal and cash-for-cars service throughout central North Carolina. Free towing included in all areas."
    showForm={false}
  />

  <!-- Map Section Placeholder -->
  <section class="section-padding bg-white">
    <div class="container-content">
      <div class="max-w-4xl mx-auto">
        <div class="bg-charcoal-100 rounded-2xl aspect-video flex items-center justify-center mb-8">
          <div class="text-center p-8">
            <svg class="w-16 h-16 text-charcoal-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <p class="text-charcoal-600">Interactive Map Coming Soon</p>
            <p class="text-charcoal-500 text-sm mt-2">Serving central North Carolina from our Sanford base</p>
          </div>
        </div>

        <div class="text-center">
          <h2 class="text-display-sm font-bold text-charcoal-950 mb-4">Coverage Radius</h2>
          <p class="text-charcoal-600 max-w-2xl mx-auto">
            Based in Sanford, NC, we regularly service locations within approximately 50 miles. 
            Don't see your area? Call us—we may still be able to help or recommend a trusted partner.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Cities by County -->
  <section class="section-padding bg-charcoal-50">
    <div class="container-content">
      <h2 class="text-display-md font-bold text-charcoal-950 text-center mb-12">Cities & Towns We Serve</h2>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {counties.map(county => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-charcoal-100">
            <h3 class="text-xl font-bold text-charcoal-950 mb-4 flex items-center gap-2">
              <svg class="w-5 h-5 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              {county.name} County
            </h3>
            <div class="space-y-2">
              {county.cities.map(city => (
                <a 
                  href={`/cities/${city.slug}`}
                  class="flex items-center justify-between p-3 rounded-lg hover:bg-charcoal-50 transition-colors group"
                >
                  <span class="font-medium text-charcoal-900 group-hover:text-brand-orange transition-colors">
                    {city.name}
                  </span>
                  <span class="text-sm text-charcoal-500">{city.distance}</span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Area Features -->
  <section class="section-padding bg-white">
    <div class="container-content">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-display-md font-bold text-charcoal-950 mb-4">Service Area Features</h2>
        <p class="text-charcoal-600">
          Consistent, professional service no matter where you are in our coverage area.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="text-center p-6">
          <div class="w-14 h-14 bg-brand-orange/10 text-brand-orange rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h4 class="font-semibold text-charcoal-900 mb-2">Same-Day Service</h4>
          <p class="text-sm text-charcoal-600">Available in most areas when you call early</p>
        </div>

        <div class="text-center p-6">
          <div class="w-14 h-14 bg-brand-orange/10 text-brand-orange rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
          </div>
          <h4 class="font-semibold text-charcoal-900 mb-2">Rural Pickup</h4>
          <p class="text-sm text-charcoal-600">We go to properties outside city limits</p>
        </div>

        <div class="text-center p-6">
          <div class="w-14 h-14 bg-brand-orange/10 text-brand-orange rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h4 class="font-semibold text-charcoal-900 mb-2">Fair Local Pricing</h4>
          <p class="text-sm text-charcoal-600">Competitive rates based on local markets</p>
        </div>

        <div class="text-center p-6">
          <div class="w-14 h-14 bg-brand-orange/10 text-brand-orange rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h4 class="font-semibold text-charcoal-900 mb-2">Licensed in NC</h4>
          <p class="text-sm text-charcoal-600">Properly licensed for all service areas</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Not in Our Area? -->
  <section class="section-padding bg-charcoal-900 text-white">
    <div class="container-content">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-display-md font-bold text-white mb-6">Don't See Your Area?</h2>
        <p class="text-xl text-charcoal-300 mb-8">
          We may still be able to help, or we can connect you with a trusted partner in your area. 
          Call us to discuss your location.
        </p>
        <a href={formatPhoneLink(BUSINESS.phone)} class="btn-primary text-lg py-4 px-8 inline-flex items-center">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call {BUSINESS.phoneDisplay}
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-gradient-to-br from-graphite-600 to-charcoal-900 text-white">
    <div class="container-content">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-display-md font-bold text-white mb-6">Ready to Sell Your Junk Car?</h2>
        <p class="text-xl text-charcoal-300 mb-8">
          Get a free quote for your vehicle, no matter where you are in our service area.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/sell-your-junk-car" class="btn-primary text-lg py-4 px-8">
            Get My Quote
          </a>
          <a href={formatPhoneLink(BUSINESS.phone)} class="btn-outline border-white text-white hover:bg-white hover:text-charcoal-900 text-lg py-4 px-8">
            Call Now
          </a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
