---
import MainLayout from '../layouts/MainLayout.astro';
import ConsumerEstimateForm from '../components/forms/ConsumerEstimateForm.astro';
import BusinessForm from '../components/forms/BusinessForm.astro';
import UrgentCallbackForm from '../components/forms/UrgentCallbackForm.astro';
import { BUSINESS, ORGANIZATION_SCHEMA } from '../utils/constants';
import { formatPhoneLink } from '../utils/helpers';

const title = 'Contact Us | MG Salvage - Sanford, NC';
const description = 'Contact MG Salvage for junk car quotes, business vehicle removal, or general inquiries. Phone: (919) 777-5427. Serving Sanford, NC and surrounding areas. Same-day pickup available.';
const keywords = 'contact MG Salvage, junk car quote phone, salvage yard contact, vehicle removal contact, Sanford NC salvage contact';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  mainEntity: {
    '@type': 'Organization',
    name: BUSINESS.name,
    telephone: BUSINESS.phone,
    email: BUSINESS.email,
    address: {
      '@type': 'PostalAddress',
      streetAddress: BUSINESS.address.street,
      addressLocality: BUSINESS.address.city,
      addressRegion: BUSINESS.address.state,
      postalCode: BUSINESS.address.zip,
      addressCountry: 'US'
    }
  }
};

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Contact', url: '/contact' }
];

const contactMethods = [
  {
    title: 'Phone',
    value: BUSINESS.phoneDisplay,
    href: formatPhoneLink(BUSINESS.phone),
    description: 'Fastest response for quotes and urgent pickup',
    icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
    primary: true
  },
  {
    title: 'Email',
    value: BUSINESS.email,
    href: `mailto:${BUSINESS.email}`,
    description: 'For general inquiries and business accounts',
    icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
    primary: false
  },
  {
    title: 'Hours',
    value: 'Mon-Fri: 8am-6pm',
    secondaryValue: 'Sat: 9am-4pm',
    description: 'Sunday: Closed',
    icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
    primary: false
  },
  {
    title: 'Address',
    value: BUSINESS.address.full,
    description: 'Sanford, NC headquarters',
    icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
    primary: false
  }
];

const quickLinks = [
  { name: 'Sell Your Junk Car', url: '/sell-your-junk-car', description: 'Get a quote for your vehicle' },
  { name: 'Business Removal', url: '/business-vehicle-removal', description: 'Commercial vehicle services' },
  { name: 'Service Areas', url: '/areas', description: 'Cities we serve' },
  { name: 'FAQ', url: '/faq', description: 'Common questions answered' }
];
---

<MainLayout title={title} description={description} keywords={keywords} schema={[schema]} breadcrumbs={breadcrumbs}>
  <!-- Header Section -->
  <section class="section-padding bg-gradient-to-br from-charcoal-900 to-graphite-900 text-white">
    <div class="container-content">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-display-lg font-bold mb-6">Contact Us</h1>
        <p class="text-xl text-charcoal-300 mb-8">
          Ready to sell your junk car or need business vehicle removal? 
          We're here to help. Reach out for a fast, free quote.
        </p>
        
        <!-- Primary CTA -->
        <a 
          href={formatPhoneLink(BUSINESS.phone)} 
          class="inline-flex items-center gap-3 bg-brand-orange hover:bg-brand-orange-dark text-white font-bold text-xl py-4 px-8 rounded-xl transition-colors"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call {BUSINESS.phoneDisplay}
        </a>
        <p class="text-charcoal-400 mt-4">Average answer time: 5 minutes</p>
      </div>
    </div>
  </section>

  <!-- Contact Methods Grid -->
  <section class="section-padding bg-white">
    <div class="container-content">
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {contactMethods.map(method => (
          <a 
            href={method.href}
            class={`rounded-xl p-6 border transition-all ${method.primary ? 'bg-brand-orange/5 border-brand-orange/20 hover:border-brand-orange/40' : 'bg-charcoal-50 border-charcoal-100 hover:border-charcoal-300'}`}
          >
            <div class={`w-12 h-12 rounded-xl flex items-center justify-center mb-4 ${method.primary ? 'bg-brand-orange text-white' : 'bg-white text-brand-teal'}`}>
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={method.icon} />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-charcoal-900 mb-1">{method.title}</h3>
            <p class="text-brand-orange font-medium mb-1">{method.value}</p>
            {method.secondaryValue && (
              <p class="text-brand-orange font-medium mb-1">{method.secondaryValue}</p>
            )}
            <p class="text-sm text-charcoal-500">{method.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Quick Links -->
  <section class="section-padding bg-charcoal-50">
    <div class="container-content">
      <h2 class="text-display-md font-bold text-charcoal-950 text-center mb-8">Quick Links</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 max-w-4xl mx-auto">
        {quickLinks.map(link => (
          <a 
            href={link.url}
            class="bg-white rounded-xl p-6 border border-charcoal-100 hover:shadow-md transition-shadow"
          >
            <h3 class="font-semibold text-charcoal-900 mb-1">{link.name}</h3>
            <p class="text-sm text-charcoal-500">{link.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Forms Section -->
  <section class="section-padding bg-white">
    <div class="container-content">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-display-md font-bold text-charcoal-950 mb-4">Get a Quote Online</h2>
        <p class="text-charcoal-600">
          Choose the option that best fits your needs. All quotes are free with no obligation.
        </p>
      </div>

      <div class="grid lg:grid-cols-3 gap-8">
        <!-- Consumer Form -->
        <div class="bg-charcoal-50 rounded-2xl p-6 border border-charcoal-100">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 bg-brand-orange/10 text-brand-orange rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-charcoal-900">Individual Seller</h3>
              <p class="text-sm text-charcoal-500">Sell your personal vehicle</p>
            </div>
          </div>
          <ConsumerEstimateForm showTitle={false} />
        </div>

        <!-- Business Form -->
        <div class="bg-charcoal-50 rounded-2xl p-6 border border-charcoal-100">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 bg-brand-teal/10 text-brand-teal rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-charcoal-900">Business Account</h3>
              <p class="text-sm text-charcoal-500">Commercial vehicle removal</p>
            </div>
          </div>
          <BusinessForm showTitle={false} />
        </div>

        <!-- Urgent Form -->
        <div class="bg-charcoal-50 rounded-2xl p-6 border border-charcoal-100">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 bg-red-100 text-red-600 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-charcoal-900">Urgent Callback</h3>
              <p class="text-sm text-charcoal-500">Need immediate pickup</p>
            </div>
          </div>
          <UrgentCallbackForm showTitle={false} />
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section Placeholder -->
  <section class="section-padding bg-charcoal-50">
    <div class="container-content">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-display-md font-bold text-charcoal-950 mb-6">Service Area</h2>
          <p class="text-body-lg text-charcoal-600 mb-6">
            Based in Sanford, NC, we provide junk car removal and salvage services throughout 
            central North Carolina. Our service area includes Lee, Chatham, Cumberland, Harnett, 
            and Moore counties.
          </p>
          
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-orange flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              </svg>
              <div>
                <div class="font-medium text-charcoal-900">Headquarters</div>
                <div class="text-charcoal-600">{BUSINESS.address.full}</div>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-orange flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
              <div>
                <div class="font-medium text-charcoal-900">Same-Day Service</div>
                <div class="text-charcoal-600">Available in Sanford and surrounding areas</div>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-orange flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <div class="font-medium text-charcoal-900">Service Hours</div>
                <div class="text-charcoal-600">Mon-Fri: 8am-6pm, Sat: 9am-4pm</div>
              </div>
            </div>
          </div>

          <div class="mt-8">
            <a href="/areas" class="btn-outline inline-flex items-center">
              View All Service Areas
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>
          </div>
        </div>

        <div class="bg-white rounded-2xl p-4 shadow-lg border border-charcoal-100">
          <!-- Map Placeholder - In production, this would be a Google Map or similar -->
          <div class="bg-charcoal-100 rounded-xl h-96 flex items-center justify-center">
            <div class="text-center">
              <svg class="w-16 h-16 text-charcoal-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <p class="text-charcoal-600 font-medium">Map Integration</p>
              <p class="text-charcoal-500 text-sm mt-1">Google Maps or similar would be embedded here</p>
              <a 
                href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(BUSINESS.address.full)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-brand-orange hover:text-brand-orange-dark text-sm mt-4 inline-block"
              >
                Open in Google Maps →
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof -->
  <section class="section-padding bg-white">
    <div class="container-content">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-display-md font-bold text-charcoal-950 mb-4">Connect With Us</h2>
        <p class="text-charcoal-600 mb-8">
          Follow us on social media for updates, tips, and special offers.
        </p>
        <div class="flex justify-center gap-4">
          <a 
            href={BUSINESS.social.facebook}
            target="_blank"
            rel="noopener noreferrer"
            class="w-12 h-12 bg-blue-600 text-white rounded-full flex items-center justify-center hover:bg-blue-700 transition-colors"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a 
            href={BUSINESS.social.google}
            target="_blank"
            rel="noopener noreferrer"
            class="w-12 h-12 bg-red-600 text-white rounded-full flex items-center justify-center hover:bg-red-700 transition-colors"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section-padding bg-gradient-to-br from-charcoal-900 to-graphite-900 text-white">
    <div class="container-content">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-display-md font-bold text-white mb-6">Ready to Get Started?</h2>
        <p class="text-xl text-charcoal-300 mb-8">
          Call now for a free, no-obligation quote. Same-day pickup available.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={formatPhoneLink(BUSINESS.phone)} class="btn-primary text-lg py-4 px-8">
            Call {BUSINESS.phoneDisplay}
          </a>
          <a href="/sell-your-junk-car" class="btn-outline border-white text-white hover:bg-white hover:text-charcoal-900 text-lg py-4 px-8">
            Get Online Quote
          </a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
