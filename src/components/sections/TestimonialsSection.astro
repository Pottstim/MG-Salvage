---
const testimonials = [
  {
    quote: "MG Salvage made it so easy. I had an old Honda that wouldn't start sitting in my driveway for months. Called on Tuesday, they picked it up Wednesday and handed me cash. No hassle with the title either.",
    name: "Michael R.",
    location: "Sanford, NC",
    type: "consumer",
    amount: "$485"
  },
  {
    quote: "As a mechanic shop, we've worked with MG Salvage for over a year now. Reliable pickup, fair pricing on non-repairable vehicles, and they handle all the paperwork. One less thing to worry about.",
    name: "Dave's Auto Repair",
    location: "Fayetteville, NC",
    type: "business",
    amount: "Ongoing partner"
  },
  {
    quote: "Had a totaled car after an accident. Insurance was a mess. MG Salvage gave me a fair price and picked it up the same day from the body shop. Professional from start to finish.",
    name: "Jennifer K.",
    location: "Pittsboro, NC",
    type: "consumer",
    amount: "$1,200"
  },
  {
    quote: "We needed to clear out 12 old vehicles from our lot. MG Salvage coordinated everything in one day, brought multiple trucks, and payment was prompt. Highly recommend for dealers.",
    name: "Carolina Auto Sales",
    location: "Southern Pines, NC",
    type: "dealer",
    amount: "Lot clearing"
  }
];

const consumerReviews = testimonials.filter(t => t.type === 'consumer');
const businessReviews = testimonials.filter(t => t.type === 'business' || t.type === 'dealer');
---

<section class="section-padding bg-white">
  <div class="container-content">
    <div class="text-center max-w-3xl mx-auto mb-12">
      <h2 class="text-display-md font-bold text-charcoal-950 mb-4">What Our Customers Say</h2>
      <p class="text-body-lg text-charcoal-600">
        From individual sellers to local businesses, we pride ourselves on fast, professional service.
      </p>
    </div>
    
    <div class="grid md:grid-cols-2 gap-8">
      {/* Consumer Reviews */}
      <div>
        <h3 class="text-lg font-semibold text-charcoal-900 mb-6 flex items-center gap-2">
          <svg class="w-5 h-5 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          Individual Sellers
        </h3>
        <div class="space-y-6">
          {consumerReviews.map(review => (
            <div class="bg-charcoal-50 rounded-xl p-6 border border-charcoal-100">
              <svg class="w-8 h-8 text-brand-orange/30 mb-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
              </svg>
              <p class="text-charcoal-700 mb-4 italic">"{review.quote}"</p>
              <div class="flex items-center justify-between">
                <div>
                  <p class="font-semibold text-charcoal-900">{review.name}</p>
                  <p class="text-sm text-charcoal-500">{review.location}</p>
                </div>
                <span class="bg-brand-orange/10 text-brand-orange px-3 py-1 rounded-full text-sm font-medium">
                  {review.amount}
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>
      
      {/* Business Reviews */}
      <div>
        <h3 class="text-lg font-semibold text-charcoal-900 mb-6 flex items-center gap-2">
          <svg class="w-5 h-5 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
          Business Partners
        </h3>
        <div class="space-y-6">
          {businessReviews.map(review => (
            <div class="bg-charcoal-50 rounded-xl p-6 border border-charcoal-100">
              <svg class="w-8 h-8 text-brand-orange/30 mb-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
              </svg>
              <p class="text-charcoal-700 mb-4 italic">"{review.quote}"</p>
              <div class="flex items-center justify-between">
                <div>
                  <p class="font-semibold text-charcoal-900">{review.name}</p>
                  <p class="text-sm text-charcoal-500">{review.location}</p>
                </div>
                <span class="bg-graphite-600/10 text-graphite-700 px-3 py-1 rounded-full text-sm font-medium">
                  {review.amount}
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
    
    <div class="text-center mt-12">
      <a href="/reviews" class="btn-outline">
        Read All Reviews
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>
  </div>
</section>