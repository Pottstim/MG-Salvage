---
import { BUSINESS } from '../../utils/constants';
import { formatPhoneLink } from '../../utils/helpers';

const navItems = [
  { label: 'Home', url: '/' },
  { 
    label: 'Sell Your Car', 
    url: '/sell-your-junk-car',
    children: [
      { label: 'Get an Estimate', url: '/sell-your-junk-car' },
      { label: 'Junk Car Removal', url: '/services/junk-car-removal' },
      { label: 'Sanford NC', url: '/cash-for-junk-cars-sanford-nc' }
    ]
  },
  { 
    label: 'Business', 
    url: '/business-vehicle-removal',
    children: [
      { label: 'Business Services', url: '/business-vehicle-removal' },
      { label: 'Mechanic Shops', url: '/business/mechanic-shops' },
      { label: 'Body Shops', url: '/business/auto-body-collision' },
      { label: 'Dealers', url: '/business/used-car-dealers' }
    ]
  },
  { label: 'Service Areas', url: '/service-areas' },
  { label: 'FAQ', url: '/faq' },
  { label: 'Reviews', url: '/reviews' },
  { label: 'Contact', url: '/contact' }
];

const currentPath = Astro.url.pathname;
---

<header class="bg-white shadow-sm sticky top-0 z-50">
  <!-- Top Bar -->
  <div class="bg-charcoal-950 text-white text-sm">
    <div class="container-content py-2 flex justify-between items-center">
      <div class="flex items-center gap-4">
        <span class="hidden sm:inline text-charcoal-300">
          <span class="font-medium text-white">{BUSINESS.address.city}, NC</span> • Licensed & Insured
        </span>
      </div>
      <div class="flex items-center gap-4">
        <a 
          href={formatPhoneLink(BUSINESS.phone)} 
          class="flex items-center gap-2 font-semibold hover:text-brand-orange transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {BUSINESS.phoneDisplay}
        </a>
        <span class="text-charcoal-500">|</span>
        <span class="text-charcoal-300">Mon-Sat</span>
      </div>
    </div>
  </div>

  <!-- Main Navigation -->
  <div class="container-content py-4">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-12 h-12 bg-brand-orange rounded-lg flex items-center justify-center group-hover:bg-brand-orange-dark transition-colors">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0" />
          </svg>
        </div>
        <div>
          <div class="text-2xl font-bold text-charcoal-950 leading-none">MG Salvage</div>
          <div class="text-xs text-charcoal-500 mt-0.5">Professional Vehicle Acquisition</div>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <div class="relative group">
            <a
              href={item.url}
              class={`px-4 py-2 text-sm font-medium rounded-lg transition-colors ${
                currentPath === item.url || currentPath.startsWith(item.url + '/')
                  ? 'text-brand-orange bg-brand-orange/5'
                  : 'text-charcoal-700 hover:text-brand-orange hover:bg-charcoal-100'
              }`}
            >
              {item.label}
              {item.children && (
                <svg class="w-4 h-4 inline-block ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>
            
            {item.children && (
              <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 min-w-[220px]">
                <div class="bg-white rounded-lg shadow-lg border border-charcoal-100 py-2">
                  {item.children.map((child) => (
                    <a
                      href={child.url}
                      class={`block px-4 py-2 text-sm ${
                        currentPath === child.url
                          ? 'text-brand-orange bg-brand-orange/5'
                          : 'text-charcoal-700 hover:text-brand-orange hover:bg-charcoal-50'
                      }`}
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </nav>

      <!-- CTA Buttons -->
      <div class="hidden lg:flex items-center gap-3">
        <a href="/contact" class="btn-outline text-sm py-2 px-4">
          Request Pickup
        </a>
        <a href={formatPhoneLink(BUSINESS.phone)} class="btn-primary text-sm py-2 px-4 lg:hidden">
          Call Now
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button 
        id="mobile-menu-btn" 
        class="lg:hidden p-2 rounded-lg text-charcoal-700 hover:bg-charcoal-100"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6 menu-open" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg class="w-6 h-6 menu-close hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div id="mobile-menu" class="lg:hidden hidden bg-white border-t border-charcoal-100">
    <div class="container-content py-4 space-y-1">
      {navItems.map((item) => (
        <div class="mobile-nav-item">
          {item.children ? (
            <>
              <button class="w-full flex items-center justify-between px-4 py-3 text-charcoal-700 font-medium rounded-lg hover:bg-charcoal-50 mobile-dropdown-btn">
                {item.label}
                <svg class="w-5 h-5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="hidden pl-4 space-y-1 mobile-dropdown">
                {item.children.map((child) => (
                  <a
                    href={child.url}
                    class={`block px-4 py-2 text-sm rounded-lg ${
                      currentPath === child.url
                        ? 'text-brand-orange bg-brand-orange/5'
                        : 'text-charcoal-600 hover:text-brand-orange hover:bg-charcoal-50'
                    }`}
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </>
          ) : (
            <a
              href={item.url}
              class={`block px-4 py-3 text-charcoal-700 font-medium rounded-lg ${
                currentPath === item.url
                  ? 'text-brand-orange bg-brand-orange/5'
                  : 'hover:bg-charcoal-50'
              }`}
            >
              {item.label}
            </a>
          )}
        </div>
      ))}
      <div class="pt-4 space-y-3">
        <a href="/sell-your-junk-car" class="btn-primary w-full justify-center">
          Get My Estimate
        </a>
        <a href={formatPhoneLink(BUSINESS.phone)} class="btn-secondary w-full justify-center">
          Call {BUSINESS.phoneDisplay}
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuOpen = mobileMenuBtn?.querySelector('.menu-open');
  const menuClose = mobileMenuBtn?.querySelector('.menu-close');
  
  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    menuOpen?.classList.toggle('hidden');
    menuClose?.classList.toggle('hidden');
  });
  
  // Mobile dropdowns
  document.querySelectorAll('.mobile-dropdown-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const dropdown = btn.nextElementSibling;
      const arrow = btn.querySelector('svg');
      dropdown?.classList.toggle('hidden');
      arrow?.classList.toggle('rotate-180');
    });
  });
</script>
