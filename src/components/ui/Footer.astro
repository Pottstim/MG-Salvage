---
import { BUSINESS, SERVICE_AREAS } from '../../utils/constants';
import { formatPhoneLink } from '../../utils/helpers';

const footerLinks = {
  services: [
    { label: 'Sell Your Junk Car', url: '/sell-your-junk-car' },
    { label: 'Junk Car Removal', url: '/services/junk-car-removal' },
    { label: 'Cash for Cars Sanford', url: '/cash-for-junk-cars-sanford-nc' },
    { label: 'Business Vehicle Removal', url: '/business-vehicle-removal' }
  ],
  business: [
    { label: 'Mechanic Shops', url: '/business/mechanic-shops' },
    { label: 'Body Shops', url: '/business/auto-body-collision' },
    { label: 'Car Dealers', url: '/business/used-car-dealers' },
    { label: 'Fleet Services', url: '/business-vehicle-removal' }
  ],
  company: [
    { label: 'About Us', url: '/about' },
    { label: 'How It Works', url: '/about#how-it-works' },
    { label: 'Reviews', url: '/reviews' },
    { label: 'FAQ', url: '/faq' }
  ],
  areas: SERVICE_AREAS.slice(0, 6).map(area => ({
    label: area.name,
    url: `/areas/${area.slug}`
  }))
};

const currentYear = new Date().getFullYear();
---

<footer class="bg-charcoal-950 text-charcoal-300">
  <!-- CTA Section -->
  <div class="border-b border-charcoal-800">
    <div class="container-content py-12">
      <div class="flex flex-col lg:flex-row items-center justify-between gap-6">
        <div class="text-center lg:text-left">
          <h3 class="text-2xl font-bold text-white mb-2">Ready to sell your vehicle?</h3>
          <p class="text-charcoal-400">Get a free estimate today. Same-day pickup available in Sanford and surrounding areas.</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/sell-your-junk-car" class="btn-primary">
            Get My Estimate
          </a>
          <a href={formatPhoneLink(BUSINESS.phone)} class="btn-outline border-charcoal-600 text-white hover:bg-charcoal-800">
            Call {BUSINESS.phoneDisplay}
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Footer -->
  <div class="container-content py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12">
      <!-- Brand Column -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 bg-brand-orange rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0" />
            </svg>
          </div>
          <div>
            <div class="text-xl font-bold text-white">MG Salvage</div>
            <div class="text-xs text-charcoal-500">Professional Vehicle Acquisition</div>
          </div>
        </a>
        <p class="text-sm mb-6 max-w-sm">
          Professional salvage and vehicle acquisition company headquartered in Sanford, NC. 
          Organized like a larger company, accessible like a local partner.
        </p>
        <div class="space-y-3 text-sm">
          <a href={formatPhoneLink(BUSINESS.phone)} class="flex items-center gap-2 hover:text-white transition-colors">
            <svg class="w-5 h-5 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {BUSINESS.phoneDisplay}
          </a>
          <a href={`mailto:${BUSINESS.email}`} class="flex items-center gap-2 hover:text-white transition-colors">
            <svg class="w-5 h-5 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            {BUSINESS.email}
          </a>
          <div class="flex items-start gap-2">
            <svg class="w-5 h-5 text-brand-orange mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>{BUSINESS.address.full}</span>
          </div>
        </div>
      </div>

      <!-- Links Columns -->
      <div>
        <h4 class="text-white font-semibold mb-4">Services</h4>
        <ul class="space-y-2 text-sm">
          {footerLinks.services.map(link => (
            <li>
              <a href={link.url} class="hover:text-white transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-4">For Business</h4>
        <ul class="space-y-2 text-sm">
          {footerLinks.business.map(link => (
            <li>
              <a href={link.url} class="hover:text-white transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-4">Service Areas</h4>
        <ul class="space-y-2 text-sm">
          {footerLinks.areas.map(link => (
            <li>
              <a href={link.url} class="hover:text-white transition-colors">{link.label}</a>
            </li>
          ))}
          <li>
            <a href="/service-areas" class="text-brand-orange hover:text-brand-orange-light transition-colors">
              View All Areas →
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-charcoal-800">
    <div class="container-content py-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-charcoal-500">
        <div>
          © {currentYear} {BUSINESS.legalName}. All rights reserved.
        </div>
        <div class="flex items-center gap-6">
          <a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a>
          <a href="/terms" class="hover:text-white transition-colors">Terms of Service</a>
          <span class="hidden md:inline">Licensed & Insured in NC</span>
        </div>
      </div>
    </div>
  </div>
</footer>
