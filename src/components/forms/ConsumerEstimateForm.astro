---
import { VEHICLE_CONDITIONS, TITLE_STATUS } from '../../utils/constants';

export interface Props {
  showTitle?: boolean;
  compact?: boolean;
  location?: string;
}

const { showTitle = true, compact = false, location } = Astro.props;
---

<form 
  action="/api/submit-consumer" 
  method="POST" 
  class="space-y-6"
  data-form-type="consumer"
>
  {showTitle && (
    <div class="text-center mb-8">
      <h3 class="text-2xl font-bold text-charcoal-950 mb-2">
        Get Your Free Estimate
      </h3>
      <p class="text-charcoal-600">
        {location ? `Tell us about your vehicle in ${location}` : 'Tell us about your vehicle'}
      </p>
    </div>
  )}
  
  <!-- Contact Info -->
  <div class="grid md:grid-cols-2 gap-4">
    <div>
      <label for="name" class="block text-sm font-medium text-charcoal-700 mb-1">
        Full Name <span class="text-brand-orange">*</span>
      </label>
      <input
        type="text"
        id="name"
        name="name"
        required
        placeholder="John Smith"
        class="w-full px-4 py-3 rounded-lg border border-charcoal-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/20 outline-none transition-all"
      />
    </div>
    
    <div>
      <label for="phone" class="block text-sm font-medium text-charcoal-700 mb-1">
        Phone Number <span class="text-brand-orange">*</span>
      </label>
      <input
        type="tel"
        id="phone"
        name="phone"
        required
        placeholder="(919) 555-0123"
        class="w-full px-4 py-3 rounded-lg border border-charcoal-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/20 outline-none transition-all"
      />
    </div>
  </div>
  
  <div class="grid md:grid-cols-2 gap-4">
    <div>
      <label for="email" class="block text-sm font-medium text-charcoal-700 mb-1">
        Email <span class="text-charcoal-400 font-normal">(optional)</span>
      </label>
      <input
        type="email"
        id="email"
        name="email"
        placeholder="john@example.com"
        class="w-full px-4 py-3 rounded-lg border border-charcoal-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/20 outline-none transition-all"
      />
    </div>
    
    <div>
      <label for="city" class="block text-sm font-medium text-charcoal-700 mb-1">
        City <span class="text-brand-orange">*</span>
      </label>
      <input
        type="text"
        id="city"
        name="city"
        required
        value={location || ''}
        placeholder="Sanford"
        class="w-full px-4 py-3 rounded-lg border border-charcoal-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/20 outline-none transition-all"
      />
    </div>
  </div>
  
  <!-- Vehicle Info -->
  <div class="border-t border-charcoal-200 pt-6">
    <h4 class="text-lg font-semibold text-charcoal-900 mb-4">Vehicle Information</h4>
    
    <div class="grid md:grid-cols-3 gap-4 mb-4">
      <div>
        <label for="year" class="block text-sm font-medium text-charcoal-700 mb-1">
          Year <span class="text-brand-orange">*</span>
        </label>
        <select
          id="year"
          name="year"
          required
          class="w-full px-4 py-3 rounded-lg border border-charcoal-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/20 outline-none transition-all"
        >
          <option value="">Select Year</option>
          {Array.from({ length: 35 }, (_, i) => 2025 - i).map(year => (
            <option value={year}>{year}</option>
          ))}
          <option value="older">Older than 1990</option>
        </select>
      </div>
      
      <div>
        <label for="make" class="block text-sm font-medium text-charcoal-700 mb-1">
          Make <span class="text-brand-orange">*</span>
        </label>
        <input
          type="text"
          id="make"
          name="make"
          required
          placeholder="Toyota"
          class="w-full px-4 py-3 rounded-lg border border-charcoal-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/20 outline-none transition-all"
        />
      </div>
      
      <div>
        <label for="model" class="block text-sm font-medium text-charcoal-700 mb-1">
          Model <span class="text-brand-orange">*</span>
        </label>
        <input
          type="text"
          id="model"
          name="model"
          required
          placeholder="Camry"
          class="w-full px-4 py-3 rounded-lg border border-charcoal-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/20 outline-none transition-all"
        />
      </div>
    </div>
    
    <!-- Condition -->
    <div class="mb-4">
      <label class="block text-sm font-medium text-charcoal-700 mb-2">
        Vehicle Condition <span class="text-brand-orange">*</span>
      </label>
      <div class="grid sm:grid-cols-2 gap-3">
        {VEHICLE_CONDITIONS.map(condition => (
          <label class="flex items-start gap-3 p-4 border border-charcoal-200 rounded-lg cursor-pointer hover:border-brand-orange transition-colors has-[:checked]:border-brand-orange has-[:checked]:bg-brand-orange/5">
            <input
              type="radio"
              name="condition"
              value={condition.id}
              required
              class="mt-1 w-4 h-4 text-brand-orange focus:ring-brand-orange"
            />
            <div>
              <div class="font-medium text-charcoal-900">{condition.label}</div>
              <div class="text-sm text-charcoal-500">{condition.description}</div>
            </div>
          </label>
        ))}
      </div>
    </div>
    
    <!-- Title Status -->
    <div class="mb-4">
      <label class="block text-sm font-medium text-charcoal-700 mb-2">
        Title Status <span class="text-brand-orange">*</span>
      </label>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {TITLE_STATUS.map(status => (
          <label class="flex items-start gap-3 p-4 border border-charcoal-200 rounded-lg cursor-pointer hover:border-brand-orange transition-colors has-[:checked]:border-brand-orange has-[:checked]:bg-brand-orange/5">
            <input
              type="radio"
              name="title_status"
              value={status.id}
              required
              class="mt-1 w-4 h-4 text-brand-orange focus:ring-brand-orange"
            />
            <div>
              <div class="font-medium text-charcoal-900">{status.label}</div>
              <div class="text-sm text-charcoal-500">{status.description}</div>
            </div>
          </label>
        ))}
      </div>
    </div>
    
    <!-- Notes -->
    <div>
      <label for="notes" class="block text-sm font-medium text-charcoal-700 mb-1">
        Additional Details <span class="text-charcoal-400 font-normal">(optional)</span>
      </label>
      <textarea
        id="notes"
        name="notes"
        rows={3}
        placeholder="Any damage, missing parts, or special circumstances..."
        class="w-full px-4 py-3 rounded-lg border border-charcoal-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/20 outline-none transition-all"
      />
    </div>
  </div>
  
  <!-- Photo Upload (Optional) -->
  <div class="border-t border-charcoal-200 pt-6">
    <label class="block text-sm font-medium text-charcoal-700 mb-2">
      Vehicle Photos <span class="text-charcoal-400 font-normal">(optional)</span>
    </label>
    <div class="border-2 border-dashed border-charcoal-300 rounded-lg p-6 text-center hover:border-brand-orange transition-colors cursor-pointer" onclick="document.getElementById('photos').click()">
      <svg class="w-12 h-12 text-charcoal-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      <p class="text-sm text-charcoal-600 mb-1">Click to upload photos</p>
      <p class="text-xs text-charcoal-400">PNG, JPG up to 10MB each</p>
      <input type="file" id="photos" name="photos" accept="image/*" multiple class="hidden" />
    </div>
  </div>
  
  <!-- Consent -->
  <div class="flex items-start gap-3">
    <input
      type="checkbox"
      id="consent"
      name="consent"
      required
      class="mt-1 w-4 h-4 text-brand-orange rounded focus:ring-brand-orange"
    />
    <label for="consent" class="text-sm text-charcoal-600">
      I agree to be contacted about my vehicle. By submitting, I confirm I own or have authority to sell this vehicle.
    </label>
  </div>
  
  <!-- Submit -->
  <button
    type="submit"
    class="btn-primary w-full text-lg py-4"
  >
    Get My Estimate
    <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
    </svg>
  </button>
  
  <p class="text-center text-sm text-charcoal-500">
    We'll respond within 30 minutes during business hours
  </p>
</form>

<script>
  // Phone formatting
  const phoneInput = document.getElementById('phone') as HTMLInputElement;
  phoneInput?.addEventListener('input', (e) => {
    const target = e.target as HTMLInputElement;
    let value = target.value.replace(/\D/g, '');
    if (value.length >= 10) {
      value = `(${value.slice(0, 3)}) ${value.slice(3, 6)}-${value.slice(6, 10)}`;
    } else if (value.length >= 6) {
      value = `(${value.slice(0, 3)}) ${value.slice(3, 6)}-${value.slice(6)}`;
    } else if (value.length >= 3) {
      value = `(${value.slice(0, 3)}) ${value.slice(3)}`;
    }
    target.value = value;
  });
</script>
