---
export interface Props {
  showTitle?: boolean;
  location?: string;
}

const { showTitle = true, location } = Astro.props;
---

<form 
  action="/api/submit-urgent" 
  method="POST" 
  class="space-y-5"
  data-form-type="urgent"
>
  {showTitle && (
    <div class="text-center mb-6">
      <h3 class="text-xl font-bold text-charcoal-950 mb-2">
        Need Pickup Today?
      </h3>
      <p class="text-charcoal-600">
        Request an urgent callback for same-day service
      </p>
    </div>
  )}
  
  <div>
    <label for="name" class="block text-sm font-medium text-charcoal-700 mb-1">
      Name <span class="text-brand-orange">*</span>
    </label>
    <input
      type="text"
      id="name"
      name="name"
      required
      placeholder="Your name"
      class="w-full px-4 py-3 rounded-lg border border-charcoal-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/20 outline-none transition-all"
    />
  </div>
  
  <div>
    <label for="phone" class="block text-sm font-medium text-charcoal-700 mb-1">
      Phone Number <span class="text-brand-orange">*</span>
    </label>
    <input
      type="tel"
      id="phone"
      name="phone"
      required
      placeholder="(919) 555-0123"
      class="w-full px-4 py-3 rounded-lg border border-charcoal-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/20 outline-none transition-all"
    />
  </div>
  
  <div>
    <label for="city" class="block text-sm font-medium text-charcoal-700 mb-1">
      City / Location <span class="text-brand-orange">*</span>
    </label>
    <input
      type="text"
      id="city"
      name="city"
      required
      value={location || ''}
      placeholder="Sanford"
      class="w-full px-4 py-3 rounded-lg border border-charcoal-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/20 outline-none transition-all"
    />
  </div>
  
  <div>
    <label for="accessibility" class="block text-sm font-medium text-charcoal-700 mb-1">
      Vehicle Location <span class="text-brand-orange">*</span>
    </label>
    <select
      id="accessibility"
      name="accessibility"
      required
      class="w-full px-4 py-3 rounded-lg border border-charcoal-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/20 outline-none transition-all"
    >
      <option value="">Select location type</option>
      <option value="driveway">Home driveway</option>
      <option value="street">Street / Curb</option>
      <option value="shop">Mechanic / Body shop</option>
      <option value="lot">Business parking lot</option>
      <option value="roadside">Roadside / Emergency</option>
      <option value="other">Other</option>
    </select>
  </div>
  
  <div>
    <label class="flex items-center gap-3 p-3 border border-charcoal-200 rounded-lg cursor-pointer hover:border-brand-orange transition-colors has-[:checked]:border-brand-orange has-[:checked]:bg-brand-orange/5">
      <input
        type="checkbox"
        id="same_day"
        name="same_day"
        value="yes"
        class="w-4 h-4 text-brand-orange rounded focus:ring-brand-orange"
      />
      <div>
        <div class="font-medium text-charcoal-900">Need pickup today</div>
        <div class="text-sm text-charcoal-500">Check for same-day priority</div>
      </div>
    </label>
  </div>
  
  <div>
    <label for="notes" class="block text-sm font-medium text-charcoal-700 mb-1">
      Quick Description <span class="text-charcoal-400 font-normal">(optional)</span>
    </label>
    <textarea
      id="notes"
      name="notes"
      rows={2}
      placeholder="Year, make, model, condition..."
      class="w-full px-4 py-3 rounded-lg border border-charcoal-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/20 outline-none transition-all"
    />
  </div>
  
  <button
    type="submit"
    class="btn-primary w-full py-4"
  >
    Request Urgent Callback
    <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
    </svg>
  </button>
  
  <p class="text-center text-xs text-charcoal-500">
    We typically respond within 15-30 minutes
  </p>
</form>

<script>
  const phoneInput = document.getElementById('phone') as HTMLInputElement;
  phoneInput?.addEventListener('input', (e) => {
    const target = e.target as HTMLInputElement;
    let value = target.value.replace(/\D/g, '');
    if (value.length >= 10) {
      value = `(${value.slice(0, 3)}) ${value.slice(3, 6)}-${value.slice(6, 10)}`;
    } else if (value.length >= 6) {
      value = `(${value.slice(0, 3)}) ${value.slice(3, 6)}-${value.slice(6)}`;
    } else if (value.length >= 3) {
      value = `(${value.slice(0, 3)}) ${value.slice(3)}`;
    }
    target.value = value;
  });
</script>
