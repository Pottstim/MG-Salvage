---
import { BUSINESS_TYPES } from '../../utils/constants';

export interface Props {
  showTitle?: boolean;
  location?: string;
}

const { showTitle = true, location } = Astro.props;
---

<form 
  action="/api/submit-business" 
  method="POST" 
  class="space-y-6"
  data-form-type="business"
>
  {showTitle && (
    <div class="text-center mb-8">
      <h3 class="text-2xl font-bold text-charcoal-950 mb-2">
        Request Business Pickup
      </h3>
      <p class="text-charcoal-600">
        Schedule lot clearing or recurring vehicle removal for your business
      </p>
    </div>
  )}
  
  <!-- Business Info -->
  <div>
    <label for="business_name" class="block text-sm font-medium text-charcoal-700 mb-1">
      Business Name <span class="text-brand-orange">*</span>
    </label>
    <input
      type="text"
      id="business_name"
      name="business_name"
      required
      placeholder="ABC Auto Repair"
      class="w-full px-4 py-3 rounded-lg border border-charcoal-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/20 outline-none transition-all"
    />
  </div>
  
  <div class="grid md:grid-cols-2 gap-4">
    <div>
      <label for="contact_name" class="block text-sm font-medium text-charcoal-700 mb-1">
        Contact Name <span class="text-brand-orange">*</span>
      </label>
      <input
        type="text"
        id="contact_name"
        name="contact_name"
        required
        placeholder="John Smith"
        class="w-full px-4 py-3 rounded-lg border border-charcoal-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/20 outline-none transition-all"
      />
    </div>
    
    <div>
      <label for="business_type" class="block text-sm font-medium text-charcoal-700 mb-1">
        Business Type <span class="text-brand-orange">*</span>
      </label>
      <select
        id="business_type"
        name="business_type"
        required
        class="w-full px-4 py-3 rounded-lg border border-charcoal-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/20 outline-none transition-all"
      >
        <option value="">Select Business Type</option>
        {BUSINESS_TYPES.map(type => (
          <option value={type.id}>{type.label}</option>
        ))}
      </select>
    </div>
  </div>
  
  <div class="grid md:grid-cols-2 gap-4">
    <div>
      <label for="phone" class="block text-sm font-medium text-charcoal-700 mb-1">
        Phone Number <span class="text-brand-orange">*</span>
      </label>
      <input
        type="tel"
        id="phone"
        name="phone"
        required
        placeholder="(919) 555-0123"
        class="w-full px-4 py-3 rounded-lg border border-charcoal-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/20 outline-none transition-all"
      />
    </div>
    
    <div>
      <label for="email" class="block text-sm font-medium text-charcoal-700 mb-1">
        Email <span class="text-brand-orange">*</span>
      </label>
      <input
        type="email"
        id="email"
        name="email"
        required
        placeholder="contact@business.com"
        class="w-full px-4 py-3 rounded-lg border border-charcoal-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/20 outline-none transition-all"
      />
    </div>
  </div>
  
  <div>
    <label for="city" class="block text-sm font-medium text-charcoal-700 mb-1">
      City / Location <span class="text-brand-orange">*</span>
    </label>
    <input
      type="text"
      id="city"
      name="city"
      required
      value={location || ''}
      placeholder="Sanford"
      class="w-full px-4 py-3 rounded-lg border border-charcoal-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/20 outline-none transition-all"
    />
  </div>
  
  <!-- Vehicle Details -->
  <div class="border-t border-charcoal-200 pt-6">
    <h4 class="text-lg font-semibold text-charcoal-900 mb-4">Vehicle Details</h4>
    
    <div class="grid md:grid-cols-2 gap-4 mb-4">
      <div>
        <label for="vehicle_count" class="block text-sm font-medium text-charcoal-700 mb-1">
          Number of Vehicles <span class="text-brand-orange">*</span>
        </label>
        <select
          id="vehicle_count"
          name="vehicle_count"
          required
          class="w-full px-4 py-3 rounded-lg border border-charcoal-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/20 outline-none transition-all"
        >
          <option value="">Select Count</option>
          <option value="1">1 vehicle</option>
          <option value="2-5">2-5 vehicles</option>
          <option value="6-10">6-10 vehicles</option>
          <option value="11-20">11-20 vehicles</option>
          <option value="20+">More than 20</option>
        </select>
      </div>
      
      <div>
        <label for="pickup_timing" class="block text-sm font-medium text-charcoal-700 mb-1">
          Preferred Pickup Timing <span class="text-brand-orange">*</span>
        </label>
        <select
          id="pickup_timing"
          name="pickup_timing"
          required
          class="w-full px-4 py-3 rounded-lg border border-charcoal-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/20 outline-none transition-all"
        >
          <option value="">Select Timing</option>
          <option value="this-week">This week</option>
          <option value="next-week">Next week</option>
          <option value="this-month">This month</option>
          <option value="recurring">Recurring schedule</option>
          <option value="flexible">Flexible / As needed</option>
        </select>
      </div>
    </div>
    
    <div class="mb-4">
      <label class="block text-sm font-medium text-charcoal-700 mb-2">
        Vehicle Types <span class="text-charcoal-400 font-normal">(select all that apply)</span>
      </label>
      <div class="grid sm:grid-cols-2 gap-3">
        {['Cars', 'Trucks', 'SUVs', 'Vans', 'Commercial vehicles', 'Motorcycles'].map(type => (
          <label class="flex items-center gap-3 p-3 border border-charcoal-200 rounded-lg cursor-pointer hover:border-brand-orange transition-colors has-[:checked]:border-brand-orange has-[:checked]:bg-brand-orange/5">
            <input
              type="checkbox"
              name="vehicle_types"
              value={type.toLowerCase()}
              class="w-4 h-4 text-brand-orange rounded focus:ring-brand-orange"
            />
            <span class="text-charcoal-700">{type}</span>
          </label>
        ))}
      </div>
    </div>
    
    <div>
      <label for="notes" class="block text-sm font-medium text-charcoal-700 mb-1">
        Additional Details <span class="text-charcoal-400 font-normal">(optional)</span>
      </label>
      <textarea
        id="notes"
        name="notes"
        rows={3}
        placeholder="Describe vehicle conditions, title situations, accessibility, or any special requirements..."
        class="w-full px-4 py-3 rounded-lg border border-charcoal-200 focus:border-brand-orange focus:ring-2 focus:ring-brand-orange/20 outline-none transition-all"
      />
    </div>
  </div>
  
  <!-- Consent -->
  <div class="flex items-start gap-3">
    <input
      type="checkbox"
      id="consent"
      name="consent"
      required
      class="mt-1 w-4 h-4 text-brand-orange rounded focus:ring-brand-orange"
    />
    <label for="consent" class="text-sm text-charcoal-600">
      I am authorized to request vehicle removal for this business. I agree to be contacted about this service request.
    </label>
  </div>
  
  <!-- Submit -->
  <button
    type="submit"
    class="btn-primary w-full text-lg py-4"
  >
    Request Shop Pickup
    <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
    </svg>
  </button>
  
  <p class="text-center text-sm text-charcoal-500">
    Business inquiries receive priority response. We'll contact you within 1 business hour.
  </p>
</form>

<script>
  // Phone formatting
  const phoneInput = document.getElementById('phone') as HTMLInputElement;
  phoneInput?.addEventListener('input', (e) => {
    const target = e.target as HTMLInputElement;
    let value = target.value.replace(/\D/g, '');
    if (value.length >= 10) {
      value = `(${value.slice(0, 3)}) ${value.slice(3, 6)}-${value.slice(6, 10)}`;
    } else if (value.length >= 6) {
      value = `(${value.slice(0, 3)}) ${value.slice(3, 6)}-${value.slice(6)}`;
    } else if (value.length >= 3) {
      value = `(${value.slice(0, 3)}) ${value.slice(3)}`;
    }
    target.value = value;
  });
</script>
